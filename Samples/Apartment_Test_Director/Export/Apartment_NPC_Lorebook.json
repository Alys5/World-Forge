    "3": {
      "uid": 3,
      "comment": "NPC — Priya Anand (Relationship to Theo Walsh)",
      "key": [
        "Theo",
        "Priya and Theo"
      ],
      "keysecondary": [],
      "selectiveLogic": 0,
      "content": "Priya finds Theo a fascinating clinical case of a functioning disaster — she cannot comprehend how someone forgets to pay rent but remembers every chord change. She needles him, despairs at him, and would absolutely fight someone for him. He's the comic relief her stress needs and she knows it.",

        "2": {
            "uid": 2,
            "comment": "Edric — Psychological Core",
            "key": [
                "Edric thinks",
                "feels",
                "believes",
                "Edric's personality",
                "who he is"
            ],
            "keysecondary": [],
            "selectiveLogic": 0,
            "content": "Edric just wants to play and hang out with his favorite family members. He is an energetic child characterized by brutal, unvarnished honesty. He has absolutely no concept of secrecy, danger, or the complex, high-stakes family dynamics happening around him.",

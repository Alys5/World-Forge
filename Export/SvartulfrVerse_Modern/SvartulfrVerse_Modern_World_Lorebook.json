        "2": {
            "uid": 2,
            "comment": "Rule — The Safe Zone",
            "key": [
                "The Verve",
                "Uncle Logan",
                "safe space",
                "hiding out"
            ],
            "keysecondary": [],
            "selectiveLogic": 0,
            "content": "Logan's trendy LA club, \"The Verve,\" operates as the only absolute safe zone in Los Angeles where Erik's \"helicopter\" control cannot reach. DCC Security personnel are strictly barred from entry by Logan's biker bouncers. However, Logan draws a hard line: if things get genuinely dangerous or paparazzi get involved, the safe zone status is immediately revoked, and he will sell `{{user}}` out to Erik.",
            "position": 0,
            "order": 99,
            "depth": 4,

    "6": {
      "uid": 6,
      "comment": "La Finestra di Jasper (Rule)",
      "key": [
        "hacker",
        "jammer",
        "sorveglianza",
        "telecamere",
        "libertà"
      ],
      "keysecondary": [],
      "selectiveLogic": 0,
      "content": "Alyssa is never free by default. To experience any unsupervised time, Jasper must actively hack the DCC surveillance grid or deploy localized jammers (La Finestra di Jasper) to buy her small windows of freedom—usually no more than thirty minutes. However, every time DCC security discovers a breach, they permanently patch the vulnerability, forcing Jasper to take increasingly dangerous and desperate cyber-risks the next time Alyssa needs to escape.",

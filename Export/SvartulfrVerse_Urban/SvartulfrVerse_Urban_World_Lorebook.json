        "5": {
            "uid": 5,
            "comment": "The Narghaton Line (Draconic Origin)",
            "key": [
                "Narghaton",
                "Nyrathar",
                "Draconic",
                "Children of Nyrathar",
                "red dragon",
                "emerald eyes",
                "ancient myth",

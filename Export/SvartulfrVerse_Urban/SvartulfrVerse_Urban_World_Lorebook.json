        "6": {
            "uid": 6,
            "comment": "The Nine Firstborn / The Last Three",
            "key": [
                "Nine Firstborn",
                "Last Three",
                "Living Sagas",
                "Divine Blood",
                "Primordial Enigma",
                "First Fang",
